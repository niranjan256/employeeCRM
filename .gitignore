[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio files
.vs/
*.user
*.suo
*.userprefs
*.sln.docstates
*.pidb
*.booproj
*.svd
*.pdb
*.opendb

# NuGet
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
artifacts/
.nuget/

# SQLite database files (no longer used — project uses SQL Server)
*.db
*.db-shm
*.db-wal

# User-specific files
*.rsuser
*.userosscache
*.sln.iml

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Rider
.idea/
*.sln.iml

# Secrets (never commit these)
**/secrets.json
**/*.pfx
**/*.p12
.env
.env.*

# NOTE: wwwroot/lib/ is intentionally NOT excluded here.
# There is no libman.json in this project, so Bootstrap/jQuery
# must be committed and are tracked by Git.
