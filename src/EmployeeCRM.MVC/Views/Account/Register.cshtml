@model EmployeeCRM.Shared.DTOs.RegisterDto
@{
    ViewData["Title"] = "Register User";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 glass-card">
            <div class="card-body p-4">
                <h4 class="card-title fw-bold mb-4">Register New CRM User</h4>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label">Username</label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" class="form-control" type="password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                        <div class="form-text">Minimum 6 characters.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Role" class="form-label">Role</label>
                        <select asp-for="Role" class="form-select">
                            <option value="Employee">Employee</option>
                            <option value="Manager">Manager</option>
                            <option value="Admin">Admin</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="EmployeeId" class="form-label">Link to Employee Profile (ID)</label>
                        <input asp-for="EmployeeId" class="form-control" type="number" />
                        <div class="form-text">Optional. Leaves null if Admin.</div>
                        <span asp-validation-for="EmployeeId" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Login" class="btn btn-light border">Cancel</a>
                        <button type="submit" class="btn btn-primary-custom">Register User</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
