@model EmployeeCRM.Shared.DTOs.EmployeeTaskDto
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Task Details";
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role");

    var statusBadge = Model.Status switch {
        "Completed" => "bg-success",
        "InProgress" => "bg-info text-dark",
        _ => "bg-warning text-dark"
    };
    var priorityBadge = Model.Priority switch {
        "Critical" => "bg-danger",
        "High"     => "bg-warning text-dark",
        "Medium"   => "bg-primary",
        _          => "bg-secondary"
    };
}

<div class="card border-0 shadow-sm glass-card mb-4">
    <div class="card-body p-4">
        <!-- Header -->
        <div class="d-flex align-items-start mb-4 pb-3 border-bottom">
            <div class="bg-primary text-white rounded d-flex align-items-center justify-content-center me-4 shadow-sm flex-shrink-0" style="width: 64px; height: 64px; font-size: 1.6rem;">
                <i class="fa-solid fa-clipboard-check"></i>
            </div>
            <div class="flex-grow-1">
                <h3 class="fw-bold mb-1">@Model.Title</h3>
                <p class="text-muted mb-2">@Model.Description</p>
                <span class="badge @statusBadge px-3 py-2 me-2">@Model.Status</span>
                <span class="badge @priorityBadge px-3 py-2">@Model.Priority Priority</span>
            </div>
            <div class="ms-3 d-flex gap-2 flex-shrink-0">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left me-1"></i>Back</a>
                @if (role != "Employee")
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary-custom btn-sm"><i class="fa-solid fa-pen me-1"></i>Edit</a>
                }
            </div>
        </div>

        <!-- Detail columns -->
        <div class="row g-4">
            <div class="col-md-6">
                <h5 class="fw-bold mb-3"><i class="fa-solid fa-users text-primary me-2"></i>Assignment</h5>
                <ul class="list-group list-group-flush glass-panel">
                    <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center">
                        <span class="text-muted"><i class="fa-regular fa-user me-2"></i>Assigned To</span>
                        <span class="fw-medium">@Model.AssignedToEmployeeName</span>
                    </li>
                    <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center">
                        <span class="text-muted"><i class="fa-solid fa-user-tie me-2"></i>Assigned By</span>
                        <span class="fw-medium">@Model.AssignedByEmployeeName</span>
                    </li>
                </ul>
            </div>

            <div class="col-md-6">
                <h5 class="fw-bold mb-3"><i class="fa-regular fa-calendar text-primary me-2"></i>Timeline</h5>
                <ul class="list-group list-group-flush glass-panel">
                    <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center">
                        <span class="text-muted"><i class="fa-regular fa-calendar-plus me-2"></i>Created</span>
                        <span class="fw-medium">@Model.CreatedDate.ToString("MMM dd, yyyy")</span>
                    </li>
                    <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center">
                        <span class="text-muted"><i class="fa-regular fa-calendar-xmark me-2 text-danger"></i>Due Date</span>
                        <span class="fw-medium @(Model.DueDate < DateTime.Now && Model.Status != "Completed" ? "text-danger" : "")">
                            @Model.DueDate.ToString("MMM dd, yyyy")
                            @if (Model.DueDate < DateTime.Now && Model.Status != "Completed")
                            {
                                <span class="badge bg-danger ms-1 small">Overdue</span>
                            }
                        </span>
                    </li>
                    @if (Model.CompletedDate.HasValue)
                    {
                        <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center">
                            <span class="text-muted"><i class="fa-regular fa-calendar-check me-2 text-success"></i>Completed</span>
                            <span class="fw-medium text-success">@Model.CompletedDate.Value.ToString("MMM dd, yyyy")</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>
