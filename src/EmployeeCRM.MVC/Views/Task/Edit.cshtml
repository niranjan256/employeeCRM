@model EmployeeCRM.Shared.DTOs.UpdateTaskDto
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Edit Task";
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role");
    bool isEmployee = role == "Employee";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm glass-card">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold m-0"><i class="fa-solid fa-pen-to-square text-primary me-2"></i>Edit Task</h4>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left me-1"></i>Back to Tasks</a>
                </div>

                <form asp-action="Edit" method="post">
                    <input type="hidden" name="id" value="@ViewBag.TaskId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    @if (isEmployee)
                    {
                        <!-- Employee can only update status -->
                        <div class="alert alert-info d-flex align-items-center mb-4" role="alert">
                            <i class="fa-solid fa-circle-info me-2"></i>
                            As an employee, you can only update the task status.
                        </div>
                        <div class="mb-4">
                            <label asp-for="Status" class="form-label fw-medium">Update Status</label>
                            <select asp-for="Status" class="form-select form-select-lg">
                                <option value="Pending">Pending</option>
                                <option value="InProgress">In Progress</option>
                                <option value="Completed">Completed</option>
                            </select>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-medium">Task Title</label>
                            <input asp-for="Title" class="form-control" placeholder="Brief summary of the task..." />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-medium">Detailed Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Provide full context..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-3">
                                <label asp-for="AssignedToEmployeeId" class="form-label fw-medium">Assign To</label>
                                <select asp-for="AssignedToEmployeeId" class="form-select" asp-items="ViewBag.Employees">
                                    <option value="">-- Select Employee --</option>
                                </select>
                                <span asp-validation-for="AssignedToEmployeeId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="Priority" class="form-label fw-medium">Priority</label>
                                <select asp-for="Priority" class="form-select">
                                    <option value="Low">Low</option>
                                    <option value="Medium">Medium</option>
                                    <option value="High">High</option>
                                    <option value="Critical">Critical</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="DueDate" class="form-label fw-medium">Due Date</label>
                                <input asp-for="DueDate" type="date" class="form-control" />
                                <span asp-validation-for="DueDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="Status" class="form-label fw-medium">Status</label>
                                <select asp-for="Status" class="form-select">
                                    <option value="Pending">Pending</option>
                                    <option value="InProgress">In Progress</option>
                                    <option value="Completed">Completed</option>
                                </select>
                            </div>
                        </div>
                    }

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light border">Cancel</a>
                        <button type="submit" class="btn btn-primary-custom px-4"><i class="fa-solid fa-save me-2"></i>Update Task</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
