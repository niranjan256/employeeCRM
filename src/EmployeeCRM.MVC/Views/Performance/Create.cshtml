@model EmployeeCRM.Shared.DTOs.CreatePerformanceDto
@{
    ViewData["Title"] = "Add Performance Review";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm glass-card">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold m-0"><i class="fa-solid fa-star-half-stroke text-primary me-2"></i>Performance Review</h4>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left me-1"></i>Back</a>
                </div>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="EmployeeId" class="form-label fw-medium">Employee</label>
                        <select asp-for="EmployeeId" class="form-select form-select-lg" asp-items="ViewBag.Employees">
                            <option value="">-- Select Employee --</option>
                        </select>
                        <span asp-validation-for="EmployeeId" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="ReviewPeriod" class="form-label fw-medium">Review Period</label>
                            <input asp-for="ReviewPeriod" class="form-control" placeholder="e.g. Q1 2024, Annual 2024" />
                            <span asp-validation-for="ReviewPeriod" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Rating" class="form-label fw-medium">Rating (1 to 5)</label>
                            <select asp-for="Rating" class="form-select">
                                <option value="5">5 - Excellent</option>
                                <option value="4">4 - Good</option>
                                <option value="3" selected>3 - Satisfactory</option>
                                <option value="2">2 - Needs Improvement</option>
                                <option value="1">1 - Poor</option>
                            </select>
                            <span asp-validation-for="Rating" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Comments" class="form-label fw-medium">Feedback / Comments</label>
                        <textarea asp-for="Comments" class="form-control" rows="4" placeholder="Detailed feedback..."></textarea>
                        <span asp-validation-for="Comments" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light border">Cancel</a>
                        <button type="submit" class="btn btn-primary-custom px-4"><i class="fa-solid fa-save me-2"></i>Save Review</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
