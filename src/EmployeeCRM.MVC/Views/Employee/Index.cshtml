@model IEnumerable<EmployeeCRM.Shared.DTOs.EmployeeDto>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Employees";
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role");
}

<div class="card border-0 shadow-sm glass-card">
    <div class="card-body p-4">
        
        <!-- Toolbar -->
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <form class="d-flex flex-grow-1" style="max-width: 600px;" method="get">
                <div class="input-group">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search name/email...">
                    <select name="department" class="form-select" style="max-width: 150px;">
                        <option value="">All Depts</option>
                        <option value="Engineering" selected="@(ViewBag.Department == "Engineering")">Engineering</option>
                        <option value="HR" selected="@(ViewBag.Department == "HR")">HR</option>
                        <option value="Sales" selected="@(ViewBag.Department == "Sales")">Sales</option>
                        <option value="Marketing" selected="@(ViewBag.Department == "Marketing")">Marketing</option>
                    </select>
                    <button type="submit" class="btn btn-secondary px-4"><i class="fa-solid fa-magnifying-glass"></i></button>
                    @if (ViewBag.Search != null || ViewBag.Department != null)
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                    }
                </div>
            </form>

            @if (role != "Employee")
            {
                <a asp-action="Create" class="btn btn-primary-custom"><i class="fa-solid fa-plus me-2"></i>New Employee</a>
            }
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Contact</th>
                        <th>Role</th>
                        <th>Joined</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (!Model.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">No employees found.</td></tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                        @item.FirstName.Substring(0,1)@item.LastName.Substring(0,1)
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@item.FullName</div>
                                        <div class="small text-muted">ID: #@item.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div><i class="fa-regular fa-envelope me-2 text-muted"></i>@item.Email</div>
                                <div><i class="fa-solid fa-phone me-2 text-muted"></i>@item.Phone</div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border">@item.Department</span>
                                <div class="small text-muted mt-1">@item.Designation</div>
                            </td>
                            <td>@item.DateOfJoining.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1"><i class="fa-solid fa-circle-check me-1"></i>Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-2 py-1"><i class="fa-solid fa-ban me-1"></i>Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light border text-primary" title="View Details"><i class="fa-solid fa-eye"></i></a>
                                
                                @if (role != "Employee")
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border text-secondary" title="Edit"><i class="fa-solid fa-pen"></i></a>
                                    @if (role == "Admin")
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light border text-danger" title="Deactivate"><i class="fa-solid fa-trash"></i></a>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
