@model EmployeeCRM.Shared.DTOs.CreateEmployeeDto
@{
    ViewData["Title"] = "Add New Employee";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm glass-card">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold m-0"><i class="fa-solid fa-user-plus text-primary me-2"></i>Employee Details</h4>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left me-1"></i>Back to List</a>
                </div>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label fw-medium">First Name</label>
                            <input asp-for="FirstName" class="form-control" placeholder="e.g. John" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label fw-medium">Last Name</label>
                            <input asp-for="LastName" class="form-control" placeholder="e.g. Doe" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-medium">Email Address</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="john.doe@company.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label fw-medium">Phone Number</label>
                            <input asp-for="Phone" class="form-control" placeholder="+1 (555) 000-0000" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr class="text-muted my-4" />

                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label asp-for="Department" class="form-label fw-medium">Department</label>
                            <select asp-for="Department" class="form-select">
                                <option value="">Select Department</option>
                                <option value="Engineering">Engineering</option>
                                <option value="HR">HR</option>
                                <option value="Sales">Sales</option>
                                <option value="Marketing">Marketing</option>
                                <option value="Finance">Finance</option>
                            </select>
                            <span asp-validation-for="Department" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Designation" class="form-label fw-medium">Designation</label>
                            <input asp-for="Designation" class="form-control" placeholder="e.g. Software Engineer" />
                            <span asp-validation-for="Designation" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DateOfJoining" class="form-label fw-medium">Joining Date</label>
                            <input asp-for="DateOfJoining" class="form-control" type="date" />
                            <span asp-validation-for="DateOfJoining" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button type="reset" class="btn btn-light border">Reset</button>
                        <button type="submit" class="btn btn-primary-custom px-4"><i class="fa-solid fa-save me-2"></i>Save Employee</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
