@model EmployeeCRM.Shared.DTOs.EmployeeDto
@{
    ViewData["Title"] = "Employee Details";
}

<div class="card border-0 shadow-sm glass-card mb-4">
    <div class="card-body p-4">
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-4 shadow-sm" style="width: 80px; height: 80px; font-size: 2rem;">
                @Model.FirstName.Substring(0,1)@Model.LastName.Substring(0,1)
            </div>
            <div>
                <h3 class="fw-bold mb-1">@Model.FullName</h3>
                <div class="text-muted fs-5">@Model.Designation, @Model.Department</div>
            </div>
             <div class="ms-auto">
                 <a asp-action="Index" class="btn btn-outline-secondary me-2"><i class="fa-solid fa-arrow-left me-1"></i>Back</a>
                 <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary-custom"><i class="fa-solid fa-pen me-1"></i>Edit</a>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <h5 class="fw-bold mb-3"><i class="fa-regular fa-address-card me-2 text-primary"></i>Contact Info</h5>
                <ul class="list-group list-group-flush glass-panel">
                    <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center">
                        <span class="text-muted"><i class="fa-solid fa-envelope me-2"></i>Email</span>
                        <span class="fw-medium">@Model.Email</span>
                    </li>
                    <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center">
                        <span class="text-muted"><i class="fa-solid fa-phone me-2"></i>Phone</span>
                        <span class="fw-medium">@Model.Phone</span>
                    </li>
                </ul>
            </div>
            <div class="col-md-6">
                 <h5 class="fw-bold mb-3"><i class="fa-solid fa-briefcase me-2 text-primary"></i>Employment Details</h5>
                 <ul class="list-group list-group-flush glass-panel">
                    <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center">
                        <span class="text-muted"><i class="fa-regular fa-calendar-check me-2"></i>Joined Date</span>
                        <span class="fw-medium">@Model.DateOfJoining.ToString("MMMM dd, yyyy")</span>
                    </li>
                    <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center">
                        <span class="text-muted"><i class="fa-solid fa-toggle-on me-2"></i>Status</span>
                        <span class="fw-medium text-@(Model.IsActive ? "success" : "danger")">@(Model.IsActive ? "Active" : "Inactive")</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
