@model EmployeeCRM.Shared.DTOs.EmployeeDto
@{
    ViewData["Title"] = "Deactivate Employee";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card border-danger shadow-sm glass-card">
            <div class="card-body p-4 p-md-5 text-center">
                <div class="text-danger mb-4">
                     <i class="fa-solid fa-triangle-exclamation" style="font-size: 4rem;"></i>
                </div>
                
                <h3 class="fw-bold mb-3">Deactivate Employee?</h3>
                <p class="text-muted fs-5 mb-4">Are you sure you want to deactivate <strong>@Model.FullName</strong>?</p>
                
                <div class="alert alert-warning text-start" role="alert">
                    <i class="fa-solid fa-circle-info me-2"></i>
                    This action will soft-delete the employee. Their records, tasks, and client histories will be preserved, but they will not be able to log in.
                </div>

                <form asp-action="Delete" method="post" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="Index" class="btn btn-light border px-4">Cancel</a>
                        <button type="submit" class="btn btn-danger px-4"><i class="fa-solid fa-ban me-2"></i>Yes, Deactivate</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
